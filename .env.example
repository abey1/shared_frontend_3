# Mirrors .env — safe to commit as a template (no real tenant values).

VITE_MSAL_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_MSAL_AUTHORITY=https://your-tenant-subdomain.ciamlogin.com/your-directory-tenant-id
VITE_MSAL_REDIRECT_URI=http://localhost:5173
VITE_MSAL_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
# VITE_MSAL_KNOWN_AUTHORITIES=
# VITE_MSAL_SCOPES=User.Read
# Or API scopes, comma-separated: api://.../access_as_user
# VITE_MSAL_SIGNUP_AUTHORITY=
