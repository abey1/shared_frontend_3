# Copy to `.env` and adjust. Never commit `.env` (it is gitignored).

# --- Backend API (Nest) ---
# No trailing slash. Bare hostnames get https:// added in the client.
# Examples:
# - Production: https://api.example.com
# - Azure App Service: https://your-api.azurewebsites.net
# - Local dev + Vite proxy (vite.config.js): /api
VITE_API_BASE_URL=https://your-api.azurewebsites.net

# Optional: used only by `vite.config.js` during `npm run dev`. Browser calls `/api/...`;
# Vite forwards those to this server to avoid CORS while developing.
# VITE_DEV_API_PROXY_TARGET=http://localhost:3000

# --- Microsoft Entra External ID / MSAL ---
# VITE_MSAL_CLIENT_ID=
# VITE_MSAL_AUTHORITY=
# At least one delegated scope for your Nest API (must start with api://). The SPA uses this
# for `acquireApiAccessToken`; `openid` / `profile` / `offline_access` are merged in code.
# VITE_MSAL_API_SCOPES is not used — list API scopes in VITE_MSAL_SCOPES only.
# VITE_MSAL_SCOPES=api://YOUR_APP_CLIENT_ID/access_as_user
